# Open Model Arena — Environment Variables
#
# Copy this file to .env and fill in your values.
# docker compose reads .env automatically.

# Required: passphrase users enter to access the arena
ARENA_PASSPHRASE=change-me-to-something-secret

# Required: secret key used to sign auth tokens (any random string)
# Generate one with: openssl rand -hex 32
AUTH_TOKEN_SECRET=change-me-to-a-random-string

# API key for your model provider (referenced in models.yaml via api_key_env)
GATEWAY_API_KEY=

# Timezone (default: America/New_York)
TZ=America/New_York
